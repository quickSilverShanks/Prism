####################################################
# PostgreSQL
####################################################

POSTGRES_DB=prism
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism123

POSTGRES_HOST=postgres
POSTGRES_PORT=5432

####################################################
# Milvus
####################################################

MILVUS_HOST=milvus
MILVUS_PORT=19530

####################################################
# Ollama
####################################################


OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
OLLAMA_CHAT_MODEL=qwen3:1.7b
# OLLAMA_EMBEDDING_MODEL=dengcao/Qwen3-Embedding-0.6B
OLLAMA_RERANKER_MODEL=dengcao/Qwen3-Reranker-0.6B:Q8_0

####################################################
# HuggingFace (alternate options for future)
####################################################

MODEL_EMBEDDING=Qwen/Qwen3-Embedding-0.6B
MODEL_RERANKER=Qwen/Qwen3-Reranker-0.6B
MODEL_CHAT=Qwen/Qwen3-1.7B

####################################################
# Application
####################################################

APP_NAME=Prism
APP_ENV=development
LOG_LEVEL=INFO

UPLOAD_PATH=/app/data/uploads
PROCESSED_PATH=/app/data/processed

####################################################
# Chunking
####################################################

CHUNK_SIZE=450
CHUNK_OVERLAP=100
